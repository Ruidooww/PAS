# PAS API
PORT=3001
NODE_ENV=development
APP_BASE_URL=http://localhost:3001

# REQUIRED - PostgreSQL 16
POSTGRES_DB=pas
POSTGRES_USER=pas
POSTGRES_PASSWORD=pas_dev_password
DATABASE_URL=postgresql://pas:pas_dev_password@localhost:5544/pas

# REQUIRED - Redis
REDIS_URL=redis://localhost:6399

# REQUIRED - MinIO
MINIO_ENDPOINT=http://localhost:9900
MINIO_ACCESS_KEY=pas_dev
MINIO_SECRET_KEY=replace_with_local_minio_secret
MINIO_BUCKET=pas-dev

# REQUIRED - RAGFlow (REST client, see exp-001 + ADR-001 § 决策修订记录)
# real client implements retrieve + listDocs against /api/v1/*; mock returns deterministic fixtures.
RAGFLOW_BASE_URL=http://localhost:9380
RAGFLOW_API_KEY=replace_with_ragflow_api_key
RAGFLOW_CLIENT_MODE=mock
# RAGFlow dataset used by demo and internal QA. The mock-compatible default is e0-mock-kb.
QA_KB_ID=e0-mock-kb
PAS_KB_ID=e0-mock-kb

# Agent client (FastGPT) — MVP always uses mock; v2 智能客服 Agent will add a real impl.
# No env vars needed for MVP; provided here for v2 readiness.
# AGENT_BASE_URL=http://localhost:3010
# AGENT_API_KEY=replace_with_fastgpt_api_key

# REQUIRED - OpenAI-compatible LLM
LLM_BASE_URL=https://example-llm-provider.invalid/v1
LLM_API_KEY=replace_with_llm_api_key
LLM_MODEL=replace_with_model_id
LLM_CLIENT_MODE=mock

# REQUIRED - provider-neutral CRM adapter
CRM_PROVIDER=external
CRM_BASE_URL=https://example-crm.invalid/api
CRM_API_KEY=replace_with_crm_api_key

# REQUIRED - IdP mode. mock is local/dev only; production startup rejects IDP_MODE=mock.
IDP_MODE=mock

# REQUIRED - Feishu OAuth scaffold values (replace in real mode; do not commit real credentials)
FEISHU_APP_ID=replace_with_feishu_app_id
FEISHU_APP_SECRET=replace_with_feishu_app_secret
FEISHU_REDIRECT_URI=http://localhost:3001/auth/callback?provider=feishu

# REQUIRED - WeCom OAuth scaffold values (replace in real mode; do not commit real credentials)
WECOM_CORP_ID=replace_with_wecom_corp_id
WECOM_AGENT_ID=replace_with_wecom_agent_id
WECOM_APP_SECRET=replace_with_wecom_app_secret
WECOM_REDIRECT_URI=http://localhost:3001/auth/callback?provider=wecom

# REQUIRED - minimum 32 characters
JWT_SECRET=replace_with_at_least_32_random_characters
JWT_SESSION_TTL_SECONDS=604800

# === Runtime tuning overrides (PAS_*) - uncomment to override defaults ===
# PAS_RAGFLOW_PAGE_SIZE=30
# PAS_RAGFLOW_TOP_K=1024
# PAS_RAGFLOW_SIMILARITY_THRESHOLD=0.1
# PAS_RAGFLOW_VECTOR_SIMILARITY_WEIGHT=0.3
# PAS_RAGFLOW_RERANK_ID=gte-rerank-v2@bailian@Tongyi-Qianwen
# PAS_LLM_QA_TEMPERATURE=0.2
# PAS_LLM_REQUIREMENT_EXTRACT_TEMPERATURE=0
# PAS_LLM_PROPOSAL_SECTION_TEMPERATURE=0.2
# PAS_LLM_DEFAULT_TEMPERATURE=0.2
# PAS_QA_RETRIEVAL_TOP_K=3
# PAS_QA_HISTORY_TURNS=5
# PAS_PROPOSAL_RETRIEVAL_TOP_K=5
# PAS_PROPOSAL_WORKER_CONCURRENCY=2
# PAS_PROPOSAL_CHAPTER_RETRIES=3
# PAS_PROPOSAL_QUEUE_REMOVE_ON_COMPLETE=100
# PAS_PROPOSAL_QUEUE_REMOVE_ON_FAIL=100
# PAS_CACHE_CRM_TTL_SECONDS=300
# PAS_KB_SYNC_ENABLED=true
# PAS_KB_SYNC_CRON=0 * * * *
# PAS_KB_SYNC_ATTEMPTS=3
# PAS_KB_SYNC_WORKER_CONCURRENCY=1
# PAS_KB_SYNC_BACKOFF_DELAY_MS=1000
# PAS_KB_SYNC_QUEUE_REMOVE_ON_COMPLETE=100
# PAS_KB_SYNC_QUEUE_REMOVE_ON_FAIL=100

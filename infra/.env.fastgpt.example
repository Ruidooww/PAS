FASTGPT_VERSION=v4.14.25
FASTGPT_PORT=3010
MINIO_API_PORT=9920

# Required: local FastGPT administrator credentials and encryption keys.
DEFAULT_ROOT_PSW=replace-with-a-strong-password
ROOT_KEY=replace-with-a-random-system-key
TOKEN_KEY=replace-with-a-random-token-key
FILE_TOKEN_KEY=replace-with-a-random-file-token-key
AES256_SECRET_KEY=replace-with-a-random-32-character-key
PLUGIN_TOKEN=replace-with-a-random-plugin-token

# Required: use URL-safe alphanumeric values because they are embedded in connection URLs.
MONGO_USER=fastgpt
MONGO_PASSWORD=replace-with-a-random-alphanumeric-password
REDIS_PASSWORD=replace-with-a-random-alphanumeric-password
POSTGRES_USER=fastgpt
POSTGRES_PASSWORD=replace-with-a-random-alphanumeric-password
POSTGRES_DB=fastgpt
MINIO_ROOT_USER=fastgpt
MINIO_ROOT_PASSWORD=replace-with-a-random-password-at-least-8-characters

# Required: OpenAI-compatible chat endpoint used by FastGPT.
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=replace-with-provider-api-key
LLM_MODEL=qwen-max

# Ports
PAS_API_PORT=3001
PAS_WEB_PORT=3000
PAS_PG_PORT=5544
PAS_REDIS_PORT=6399
PAS_MINIO_PORT=9900
PAS_MINIO_CONSOLE_PORT=9901

# Resource limits (compose has defaults; uncomment to override)
# PAS_API_MEM_LIMIT=1500M
# PAS_WEB_MEM_LIMIT=512M
# PAS_PG_MEM_LIMIT=1G
# PAS_REDIS_MEM_LIMIT=256M
# PAS_MINIO_MEM_LIMIT=512M

# Shared network (set to the actual RAGFlow/FastGPT Docker network on the VM)
SHARED_NETWORK_NAME=ragflow

# API runtime
NODE_ENV=production
APP_BASE_URL=http://<vm-ip>:3001

# Database
POSTGRES_DB=pas
POSTGRES_USER=pas
POSTGRES_PASSWORD=<change_me>
DATABASE_URL=postgresql://pas:<change_me>@postgres:5432/pas

# Redis
REDIS_URL=redis://redis:6379

# MinIO
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=<change_me>
MINIO_SECRET_KEY=<change_me>
MINIO_BUCKET=pas-prod

# JWT
JWT_SECRET=<at_least_32_random_chars>
JWT_SESSION_TTL_SECONDS=604800

# IdP (production must use real; env schema rejects IDP_MODE=mock when NODE_ENV=production)
IDP_MODE=real
FEISHU_APP_ID=cli_placeholder
FEISHU_APP_SECRET=placeholder
FEISHU_REDIRECT_URI=http://<vm-ip>:3001/auth/callback?provider=feishu
WECOM_CORP_ID=ww_placeholder
WECOM_AGENT_ID=1000001
WECOM_APP_SECRET=placeholder
WECOM_REDIRECT_URI=http://<vm-ip>:3001/auth/callback?provider=wecom

# RAGFlow (same VM; use the RAGFlow container/service name reachable on SHARED_NETWORK_NAME)
RAGFLOW_BASE_URL=http://ragflow-ragflow-cpu-1:9380
RAGFLOW_API_KEY=<paste_from_ragflow_admin>
RAGFLOW_CLIENT_MODE=real
QA_KB_ID=<paste>
PAS_KB_ID=<paste>

# LLM (Bailian OpenAI-compatible endpoint)
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=<paste>
LLM_MODEL=qwen-max
LLM_CLIENT_MODE=real

# CRM (schema still requires base URL and API key even when CRM_PROVIDER=mock)
CRM_PROVIDER=mock
CRM_BASE_URL=https://example-crm.invalid/api
CRM_API_KEY=<change_me>

# Web build-time API proxy target
API_BASE_URL=http://pas-api:3001

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  presales
  aftersales
  implementation
  external
}

enum CustomerSource {
  external
  pas
}

enum ProposalStatus {
  draft
  draft_ready @map("draft-ready")
  final
}

enum FeedbackRating {
  up
  down
}

enum IdpProvider {
  feishu
  wecom
  mock
}

model Tenant {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  users     User[]

  @@map("tenants")
}

model User {
  id           String                 @id @default(cuid())
  name         String
  email        String?                @unique
  role         UserRole               @default(presales)
  isExternal   Boolean                @default(false) @map("is_external")
  deptId       String?                @map("dept_id")
  tenantId     String                 @map("tenant_id")
  idpProvider  IdpProvider            @map("idp_provider")
  idpUserId    String                 @map("idp_user_id")
  avatar       String?
  lastLoginAt  DateTime?              @map("last_login_at")
  createdAt    DateTime               @default(now()) @map("created_at")
  tenant       Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  proposals    Proposal[]             @relation("ProposalCreator")
  kbDocuments  KbDocument[]           @relation("DocumentUploader")
  auditLogs    AuditLog[]
  feedback     ConversationFeedback[]
  conversations Conversation[]

  @@index([deptId])
  @@index([tenantId])
  @@unique([idpProvider, idpUserId])
  @@map("users")
}

model CustomerMirror {
  ref       String         @id
  source    CustomerSource @default(external)
  name      String
  industry  String?
  scale     Int?
  ownerId   String?        @map("owner_id")
  syncedAt  DateTime       @map("synced_at")

  @@index([ownerId])
  @@map("customer_mirrors")
}

model Proposal {
  id              String         @id @default(cuid())
  customerRef     String         @map("customer_ref")
  opportunityRef  String?        @map("opportunity_ref")
  title           String
  status          ProposalStatus @default(draft)
  requirementJson Json           @map("requirement_json")
  contentJson     Json?          @map("content_json")
  pptFileKey      String?        @map("ppt_file_key")
  createdBy       String         @map("created_by")
  version         Int            @default(1)
  createdAt       DateTime       @default(now()) @map("created_at")
  creator         User           @relation("ProposalCreator", fields: [createdBy], references: [id], onDelete: Restrict)

  @@index([customerRef])
  @@index([opportunityRef])
  @@index([createdBy])
  @@map("proposals")
}

model KbDocument {
  id            String   @id @default(cuid())
  ragflowDocId  String   @unique @map("ragflow_doc_id")
  ragflowKbId   String   @map("ragflow_kb_id")
  name          String
  product       String?
  aclScope      String   @map("acl_scope")
  uploadedBy    String   @map("uploaded_by")
  createdAt     DateTime @default(now()) @map("created_at")
  uploader      User     @relation("DocumentUploader", fields: [uploadedBy], references: [id], onDelete: Restrict)

  @@index([ragflowKbId])
  @@index([aclScope])
  @@index([uploadedBy])
  @@map("kb_documents")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  action     String
  resource   String
  isExternal Boolean  @default(false) @map("is_external")
  detailJson Json     @map("detail_json")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model ConversationFeedback {
  id        String          @id @default(cuid())
  userId    String          @map("user_id")
  rating    FeedbackRating
  messageId String?         @unique @map("message_id")
  comment   String?         @db.Text
  createdAt DateTime        @default(now()) @map("created_at")
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   Message?        @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("conversation_feedback")
}

model Conversation {
  id        String    @id @default(cuid())
  sessionId String    @map("session_id")
  userId    String    @map("user_id")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@unique([sessionId, userId])
  @@index([userId])
  @@index([createdAt])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String       @map("conversation_id")
  role           String
  content        String       @db.Text
  refs           Json?
  createdAt      DateTime     @default(now()) @map("created_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  feedback       ConversationFeedback?

  @@index([conversationId])
  @@index([createdAt])
  @@map("messages")
}

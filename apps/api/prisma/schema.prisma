generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  presales
  aftersales
  implementation
  external
}

enum CustomerSource {
  external
  pas
}

enum ProposalStatus {
  draft
  draft_ready @map("draft-ready")
  final
}

enum FeedbackRating {
  up
  down
}

enum IdpProvider {
  feishu
  wecom
  mock
}

enum KgEntityType {
  product
  proposal
  customer
  industry
}

enum KgRelationType {
  PRODUCT_USES
  CUSTOMER_BUYS
  PROPOSAL_FOR_CUSTOMER
  INDUSTRY_HAS_CUSTOMER
  PRODUCT_COMPETES
}

model Tenant {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  users     User[]

  @@map("tenants")
}

model User {
  id           String                 @id @default(cuid())
  name         String
  email        String?                @unique
  role         UserRole               @default(presales)
  isExternal   Boolean                @default(false) @map("is_external")
  deptId       String?                @map("dept_id")
  tenantId     String                 @map("tenant_id")
  idpProvider  IdpProvider            @default(mock) @map("idp_provider")
  idpUserId    String                 @map("idp_user_id")
  avatar       String?
  lastLoginAt  DateTime?              @map("last_login_at")
  createdAt    DateTime               @default(now()) @map("created_at")
  tenant       Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  proposals    Proposal[]             @relation("ProposalCreator")
  kbDocuments  KbDocument[]           @relation("DocumentUploader")
  auditLogs    AuditLog[]
  feedback     ConversationFeedback[]
  conversations Conversation[]

  @@index([deptId])
  @@index([tenantId])
  @@unique([idpProvider, idpUserId])
  @@map("users")
}

model CustomerMirror {
  ref       String         @id
  source    CustomerSource @default(external)
  name      String
  industry  String?
  scale     Int?
  ownerId   String?        @map("owner_id")
  syncedAt  DateTime       @map("synced_at")

  @@index([ownerId])
  @@map("customer_mirrors")
}

model Proposal {
  id              String         @id @default(cuid())
  customerRef     String         @map("customer_ref")
  opportunityRef  String?        @map("opportunity_ref")
  title           String
  status          ProposalStatus @default(draft)
  requirementJson Json           @map("requirement_json")
  contentJson     Json?          @map("content_json")
  pptFileKey      String?        @map("ppt_file_key")
  createdBy       String         @map("created_by")
  version         Int            @default(1)
  createdAt       DateTime       @default(now()) @map("created_at")
  deletedAt       DateTime?      @map("deleted_at")
  creator         User           @relation("ProposalCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  versions        ProposalVersion[]

  @@index([customerRef])
  @@index([opportunityRef])
  @@index([createdBy])
  @@map("proposals")
}

model ProposalVersion {
  id          String   @id @default(cuid())
  proposalId  String   @map("proposal_id")
  version     Int
  contentJson Json     @map("content_json")
  createdAt   DateTime @default(now()) @map("created_at")
  proposal    Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@unique([proposalId, version])
  @@index([proposalId, createdAt])
  @@map("proposal_versions")
}

model KbDocument {
  id                  String    @id @default(cuid())
  ragflowDocId        String    @unique @map("ragflow_doc_id")
  ragflowKbId         String    @map("ragflow_kb_id")
  name                String
  product             String?
  aclScope            String    @default("internal") @map("acl_scope")
  sensitivity         String    @default("internal")
  chunkSensitivityMap Json      @default("{}") @map("chunk_sensitivity_map")
  uploadedBy          String?   @map("uploaded_by")
  size                Int?
  ragflowUpdatedAt    DateTime? @map("ragflow_updated_at")
  deletedAt           DateTime? @map("deleted_at")
  syncedAt            DateTime  @default(now()) @map("synced_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  uploader            User?     @relation("DocumentUploader", fields: [uploadedBy], references: [id], onDelete: Restrict)

  @@index([ragflowKbId])
  @@index([aclScope])
  @@index([uploadedBy])
  @@map("kb_documents")
}

model FieldAcl {
  id            String   @id @default(cuid())
  resourceType  String   @map("resource_type")
  resourceId    String   @map("resource_id")
  fieldName     String   @map("field_name")
  requiredRoles String[] @default([]) @map("required_roles")
  requiredAttrs Json     @default("{}") @map("required_attrs")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([resourceType, resourceId])
  @@index([resourceType, fieldName])
  @@map("field_acls")
}

model AclAuditLog {
  id           String   @id @default(cuid())
  userId       String?  @map("user_id")
  resourceType String   @map("resource_type")
  resourceId   String   @map("resource_id")
  fieldName    String?  @map("field_name")
  chunkId      String?  @map("chunk_id")
  action       String
  reason       String
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@map("acl_audit_logs")
}

model KbSyncLog {
  id           String   @id @default(cuid())
  ragflowKbId  String   @map("ragflow_kb_id")
  addedCount   Int      @default(0) @map("added_count")
  deletedCount Int      @default(0) @map("deleted_count")
  updatedCount Int      @default(0) @map("updated_count")
  status       String
  errorMessage String?  @map("error_message") @db.Text
  runAt        DateTime @default(now()) @map("run_at")

  @@index([ragflowKbId, runAt(sort: Desc)])
  @@map("kb_sync_logs")
}

model KgEntityProduct {
  id       String   @id @default(cuid())
  name     String   @unique
  category String?
  vendor   String?
  aliases  String[] @default([])
  metadata Json     @default("{}")

  @@index([name])
  @@map("kg_entity_products")
}

model KgEntityProposal {
  id         String   @id @default(cuid())
  title      String   @unique
  customerId String?  @map("customer_id")
  templateId String?  @map("template_id")
  chapters   String[] @default([])

  @@index([customerId])
  @@map("kg_entity_proposals")
}

model KgEntityCustomer {
  id       String  @id @default(cuid())
  name     String  @unique
  industry String?
  scale    String?
  crmId    String? @unique @map("crm_id")

  @@index([industry])
  @@map("kg_entity_customers")
}

model KgEntityIndustry {
  id       String             @id @default(cuid())
  name     String             @unique
  code     String?            @unique
  parentId String?            @map("parent_id")
  parent   KgEntityIndustry?  @relation("KgIndustryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children KgEntityIndustry[] @relation("KgIndustryHierarchy")

  @@index([parentId])
  @@map("kg_entity_industries")
}

model KgRelation {
  id             String         @id @default(cuid())
  fromEntityType KgEntityType   @map("from_entity_type")
  fromId         String         @map("from_id")
  toEntityType   KgEntityType   @map("to_entity_type")
  toId           String         @map("to_id")
  relationType   KgRelationType @map("relation_type")
  weight         Float          @default(1)
  source         Json
  createdAt      DateTime       @default(now()) @map("created_at")

  @@unique([fromEntityType, fromId, toEntityType, toId, relationType], map: "kg_relations_unique_edge_type")
  @@index([fromEntityType, fromId])
  @@index([toEntityType, toId])
  @@index([relationType])
  @@map("kg_relations")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  action     String
  resource   String
  isExternal Boolean  @default(false) @map("is_external")
  detailJson Json     @map("detail_json")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model ConversationFeedback {
  id        String          @id @default(cuid())
  userId    String          @map("user_id")
  rating    FeedbackRating
  messageId String?         @unique @map("message_id")
  comment   String?         @db.Text
  createdAt DateTime        @default(now()) @map("created_at")
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   Message?        @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("conversation_feedback")
}

model Conversation {
  id        String    @id @default(cuid())
  sessionId String    @map("session_id")
  userId    String    @map("user_id")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@unique([sessionId, userId])
  @@index([userId])
  @@index([createdAt])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String       @map("conversation_id")
  role           String
  content        String       @db.Text
  refs           Json?
  createdAt      DateTime     @default(now()) @map("created_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  feedback       ConversationFeedback?

  @@index([conversationId])
  @@index([createdAt])
  @@map("messages")
}

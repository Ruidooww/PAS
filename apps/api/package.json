{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --max-warnings=0",
    "postinstall": "prisma generate",
    "prisma": "prisma",
    "start": "node dist/main.js",
    "test:proposal-worker": "vitest run test/proposal-generation.service.spec.ts test/proposal-worker.e2e.spec.ts test/proposal-progress.redis.integration.spec.ts",
    "test:proposal-worker:coverage": "vitest run test/proposal-generation.service.spec.ts --coverage.enabled --coverage.provider=v8 --coverage.include=src/proposal-worker/proposal-generation.service.ts --coverage.thresholds.lines=80 --coverage.thresholds.functions=80 --coverage.thresholds.statements=80 --coverage.thresholds.branches=80",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.3",
    "@nestjs/platform-express": "^11.1.3",
    "@pas/clients": "workspace:*",
    "@pas/shared": "workspace:*",
    "@prisma/client": "^6.9.0",
    "bullmq": "^5.79.1",
    "docx": "^9.7.1",
    "ioredis": "^5.10.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "yaml": "^2.9.0",
    "zod": "^3.25.64"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/testing": "^11.1.3",
    "@types/node": "^22.15.30",
    "@vitest/coverage-v8": "^3.2.6",
    "jszip": "^3.10.1",
    "prisma": "^6.9.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  }
}
